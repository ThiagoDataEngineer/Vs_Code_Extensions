{
  "name": "dapp-agent-forge-vscode",
  "displayName": "Web3 Wallet Lab Forge",
  "description": "Web3 wallet testing, crypto/cripto balance checks, and smart contract verification in VS Code for developers, QA teams, and AI agents.",
  "version": "0.2.94",
  "icon": "media/icon.png",
  "publisher": "ShinyDapps",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/ThiagoDataEngineer/Vs_Code_Extensions"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "keywords": [
    "web3",
    "blockchain",
    "vscode",
    "vscode extension",
    "web3 wallet",
    "web3 wallet lab",
    "wallet testing",
    "wallet qa",
    "wallet checker",
    "wallet connect",
    "wallet provider",
    "wallet address",
    "address validation",
    "wallet registry",
    "balance checker",
    "crypto",
    "cripto",
    "crypto wallet",
    "cripto carteira",
    "crypto prices",
    "price tracker",
    "crypto market",
    "onchain",
    "onchain analytics",
    "onchain data",
    "smart contract",
    "contract check",
    "contract verification",
    "wallet verification",
    "web3 testing",
    "crypto testing",
    "agent testing",
    "ai agent",
    "agentic",
    "bitcoin",
    "btc",
    "ethereum",
    "solana",
    "evm",
    "xrp",
    "testnet",
    "mainnet",
    "sepolia",
    "metamask",
    "walletconnect",
    "ledger",
    "trezor",
    "binance",
    "uniswap wallet",
    "coinbase wallet",
    "trust wallet",
    "carteira cripto",
    "verificacao contrato",
    "saldo carteira",
    "portefeuille crypto",
    "verification contrat",
    "billetera cripto",
    "verificacion contrato",
    "krypto wallet",
    "wallet pruefung",
    "theme",
    "vaporwave"
  ],
  "categories": [
    "Testing",
    "Data Science",
    "Other"
  ],
  "activationEvents": [
    "onView:vaporwaveWeb3.walletView",
    "onCommand:vaporwaveWeb3.connectTestWallet",
    "onCommand:vaporwaveWeb3.disconnectWallet",
    "onCommand:vaporwaveWeb3.copyWallet",
    "onCommand:vaporwaveWeb3.runContractCheck"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vaporwaveWeb3.connectTestWallet",
        "title": "Web3 Wallet Lab: Connect Wallet"
      },
      {
        "command": "vaporwaveWeb3.disconnectWallet",
        "title": "Web3 Wallet Lab: Disconnect Wallet"
      },
      {
        "command": "vaporwaveWeb3.copyWallet",
        "title": "Web3 Wallet Lab: Copy Wallet Address"
      },
      {
        "command": "vaporwaveWeb3.runContractCheck",
        "title": "Web3 Wallet Lab: Run Contract Check"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vaporwaveWeb3",
          "title": "Wallet Lab",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "vaporwaveWeb3": [
        {
          "id": "vaporwaveWeb3.walletView",
          "name": "Web3 Wallet Lab",
          "type": "webview"
        }
      ]
    },
    "themes": [
      {
        "label": "Web3 Blockchain Vaporwave Neon Dusk",
        "uiTheme": "vs-dark",
        "path": "./themes/vaporwave-neon-dusk-color-theme.json"
      },
      {
        "label": "Web3 Blockchain Bittensor Signal",
        "uiTheme": "vs-dark",
        "path": "./themes/bittensor-signal-color-theme.json"
      },
      {
        "label": "Web3 Blockchain Lamberto Ubatuba Beach",
        "uiTheme": "vs-dark",
        "path": "./themes/lamberto-shoreline-color-theme.json"
      },
      {
        "label": "Web3 Blockchain COBOL Terminal",
        "uiTheme": "vs-dark",
        "path": "./themes/cobol-terminal-color-theme.json"
      },
      {
        "label": "Web3 Blockchain Vaporwave Midnight",
        "uiTheme": "vs-dark",
        "path": "./themes/vaporwave-midnight-color-theme.json"
      },
      {
        "label": "Web3 Blockchain Bitcoin Sober",
        "uiTheme": "vs-dark",
        "path": "./themes/bitcoin-sober-color-theme.json"
      },
      {
        "label": "Web3 Blockchain Bitcoin Calm Light",
        "uiTheme": "vs",
        "path": "./themes/bitcoin-calm-light-color-theme.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package --allow-missing-repository --skip-license --baseContentUrl https://github.com/ThiagoDataEngineer/Vs_Code_Extensions/blob/main/vaporwave-web3-forge --baseImagesUrl https://raw.githubusercontent.com/ThiagoDataEngineer/Vs_Code_Extensions/main/vaporwave-web3-forge",
    "test:real:eth-balance": "node scripts/test-real-eth-balance.mjs"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.3.2",
    "@types/node": "^20.14.9",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.57.0",
    "typescript": "^5.5.3"
  }
}
