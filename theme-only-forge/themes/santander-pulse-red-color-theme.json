{
    "$schema":  "vscode://schemas/color-theme",
    "name":  "World Banking Santander Dark",
    "type":  "dark",
    "colors":  {
                   "editor.background":  "#1B0B10",
                   "editor.foreground":  "#FFEFF1",
                   "editorLineNumber.foreground":  "#8C98AC",
                   "editorCursor.foreground":  "#E30613",
                   "editor.selectionBackground":  "#FF4D6D33",
                   "activityBar.background":  "#260B12",
                   "activityBar.foreground":  "#FFF0F2",
                   "activityBarBadge.background":  "#E30613",
                   "activityBarBadge.foreground":  "#FFFFFF",
                   "sideBar.background":  "#210A11",
                   "sideBar.foreground":  "#D8E2F2",
                   "sideBarTitle.foreground":  "#B0B4BC",
                   "list.activeSelectionBackground":  "#3A1420",
                   "list.activeSelectionForeground":  "#FFFFFF",
                   "list.hoverBackground":  "#2C1019",
                   "statusBar.background":  "#E30613",
                   "statusBar.foreground":  "#FFFFFF",
                   "titleBar.activeBackground":  "#260B12",
                   "titleBar.activeForeground":  "#FFFFFF",
                   "button.background":  "#E30613",
                   "button.foreground":  "#FFFFFF",
                   "focusBorder":  "#FF4D6D",
                   "editorLineNumber.activeForeground":  "#E30613",
                   "editor.lineHighlightBackground":  "#E5001214",
                   "editorBracketMatch.background":  "#B0B4BC1F",
                   "editorBracketMatch.border":  "#B0B4BCAA",
                   "editorIndentGuide.background1":  "#3A1A23",
                   "editorIndentGuide.activeBackground1":  "#5A2634",
                   "editorGutter.background":  "#1B0B10",
                   "editorWhitespace.foreground":  "#5A2A39",
                   "editor.selectionHighlightBackground":  "#E5001222",
                   "editor.wordHighlightBackground":  "#4A4A4A24",
                   "editor.wordHighlightStrongBackground":  "#E5001230",
                   "activityBar.inactiveForeground":  "#C27A8B",
                   "sideBar.border":  "#4A1D2A",
                   "sideBarSectionHeader.foreground":  "#B0B4BC",
                   "sideBarSectionHeader.border":  "#4A1D2A",
                   "list.inactiveSelectionBackground":  "#E5001224",
                   "list.focusBackground":  "#E5001238",
                   "list.focusForeground":  "#FFFFFF",
                   "list.highlightForeground":  "#B0B4BC",
                   "statusBar.debuggingBackground":  "#B0B4BC",
                   "statusBar.debuggingForeground":  "#FFFFFF",
                   "titleBar.inactiveBackground":  "#1A070D",
                   "titleBar.inactiveForeground":  "#C27A8B",
                   "tab.activeBackground":  "#210A11",
                   "tab.activeForeground":  "#FFF0F2",
                   "tab.inactiveBackground":  "#1A070D",
                   "tab.inactiveForeground":  "#C27A8B",
                   "tab.border":  "#4A1D2A",
                   "tab.activeBorderTop":  "#E30613",
                   "button.hoverBackground":  "#B0B4BC",
                   "input.background":  "#1A070D",
                   "input.border":  "#5A2634",
                   "input.foreground":  "#FFF0F2",
                   "input.placeholderForeground":  "#C27A8B",
                   "dropdown.background":  "#1A070D",
                   "dropdown.foreground":  "#FFF0F2",
                   "dropdown.border":  "#5A2634",
                   "badge.background":  "#E30613",
                   "badge.foreground":  "#FFFFFF",
                   "panel.background":  "#260B12",
                   "panel.border":  "#4A1D2A",
                   "panelTitle.activeBorder":  "#E30613",
                   "panelTitle.activeForeground":  "#FFF0F2",
                   "panelTitle.inactiveForeground":  "#C27A8B",
                   "terminal.background":  "#1B0B10",
                   "terminal.foreground":  "#FFEFF1",
                   "terminalCursor.foreground":  "#E50012",
                   "terminal.ansiBlack":  "#260B12",
                   "terminal.ansiRed":  "#EF4444",
                   "terminal.ansiGreen":  "#22C55E",
                   "terminal.ansiYellow":  "#EAB308",
                   "terminal.ansiBlue":  "#3B82F6",
                   "terminal.ansiMagenta":  "#A855F7",
                   "terminal.ansiCyan":  "#06B6D4",
                   "terminal.ansiWhite":  "#CBD5E1",
                   "terminal.ansiBrightBlack":  "#5A2634",
                   "terminal.ansiBrightRed":  "#F87171",
                   "terminal.ansiBrightGreen":  "#4ADE80",
                   "terminal.ansiBrightYellow":  "#FACC15",
                   "terminal.ansiBrightBlue":  "#60A5FA",
                   "terminal.ansiBrightMagenta":  "#C084FC",
                   "terminal.ansiBrightCyan":  "#22D3EE",
                   "terminal.ansiBrightWhite":  "#F8FAFC",
                   "scrollbarSlider.background":  "#B0B4BC33",
                   "scrollbarSlider.hoverBackground":  "#B0B4BC55",
                   "scrollbarSlider.activeBackground":  "#B0B4BC77",
                   "notifications.background":  "#210A11",
                   "notifications.foreground":  "#FFF0F2",
                   "notifications.border":  "#4A1D2A",
                   "minimap.background":  "#1B0B10EE",
                   "sideBarSectionHeader.background":  "#2A0F18"
               },
    "tokenColors":  [
                        {
                            "settings":  {
                                             "foreground":  "#8FA1B5",
                                             "fontStyle":  "italic"
                                         },
                            "scope":  [
                                          "comment",
                                          "punctuation.definition.comment"
                                      ]
                        },
                        {
                            "settings":  {
                                             "foreground":  "#FF7A90",
                                             "fontStyle":  "bold"
                                         },
                            "scope":  [
                                          "keyword",
                                          "storage.type",
                                          "storage.modifier",
                                          "keyword.control",
                                          "keyword.operator.new",
                                          "keyword.operator.expression",
                                          "source.cobol keyword",
                                          "source.cobol storage",
                                          "source.cobol meta.verb"
                                      ]
                        },
                        {
                            "settings":  {
                                             "foreground":  "#8EC5FF"
                                         },
                            "scope":  [
                                          "entity.name.type",
                                          "support.type",
                                          "entity.name.class",
                                          "entity.name.namespace",
                                          "storage.type.java",
                                          "source.scala storage.type",
                                          "source.python storage.type"
                                      ]
                        },
                        {
                            "settings":  {
                                             "foreground":  "#79B8FF"
                                         },
                            "scope":  [
                                          "entity.name.function",
                                          "support.function",
                                          "entity.name.function.python",
                                          "entity.name.function.java",
                                          "entity.name.function.scala",
                                          "support.function.builtin.python",
                                          "support.function.pyspark"
                                      ]
                        },
                        {
                            "settings":  {
                                             "foreground":  "#6EC1FF"
                                         },
                            "scope":  [
                                          "meta.function-call",
                                          "variable.function",
                                          "meta.method-call.java",
                                          "meta.function-call.python"
                                      ]
                        },
                        {
                            "settings":  {
                                             "foreground":  "#D6E2F2"
                                         },
                            "scope":  [
                                          "variable",
                                          "meta.definition.variable",
                                          "meta.variable.object",
                                          "variable.other.readwrite",
                                          "source.cobol variable"
                                      ]
                        },
                        {
                            "settings":  {
                                             "foreground":  "#FFD700"
                                         },
                            "scope":  [
                                          "variable.parameter",
                                          "meta.function.parameters",
                                          "meta.parameters",
                                          "variable.parameter.function"
                                      ]
                        },
                        {
                            "settings":  {
                                             "foreground":  "#A8C0DC"
                                         },
                            "scope":  [
                                          "variable.other.property",
                                          "support.variable.property",
                                          "variable.other.member",
                                          "meta.attribute",
                                          "variable.other.constant"
                                      ]
                        },
                        {
                            "settings":  {
                                             "foreground":  "#8ED89A"
                                         },
                            "scope":  [
                                          "string",
                                          "punctuation.definition.string",
                                          "string.quoted.single",
                                          "string.quoted.double"
                                      ]
                        },
                        {
                            "settings":  {
                                             "foreground":  "#FFD700"
                                         },
                            "scope":  [
                                          "constant.numeric",
                                          "constant.numeric.integer",
                                          "constant.numeric.float",
                                          "constant.language.boolean"
                                      ]
                        },
                        {
                            "settings":  {
                                             "foreground":  "#F2A7B8"
                                         },
                            "scope":  [
                                          "constant.language",
                                          "constant.character",
                                          "constant.other",
                                          "constant.other.symbol",
                                          "constant.language.solidity"
                                      ]
                        },
                        {
                            "settings":  {
                                             "foreground":  "#B9C7D8"
                                         },
                            "scope":  [
                                          "keyword.operator",
                                          "keyword.operator.logical",
                                          "keyword.operator.arithmetic"
                                      ]
                        },
                        {
                            "settings":  {
                                             "foreground":  "#FFD700",
                                             "fontStyle":  "bold"
                                         },
                            "scope":  [
                                          "source.cobol entity.name.section",
                                          "source.cobol entity.name.paragraph",
                                          "entity.name.section",
                                          "entity.name.label"
                                      ]
                        },
                        {
                            "settings":  {
                                             "foreground":  "#FFA94D",
                                             "fontStyle":  "bold"
                                         },
                            "scope":  [
                                          "source.solidity keyword",
                                          "source.solidity storage.type",
                                          "storage.type.user-defined.solidity"
                                      ]
                        },
                        {
                            "settings":  {
                                             "foreground":  "#7BDFF2"
                                         },
                            "scope":  [
                                          "source.python support.type",
                                          "source.scala support.type",
                                          "source.java support.type",
                                          "source.pyspark support.function"
                                      ]
                        }
                    ],
    "semanticTokenColors":  {
                                "class":  {
                                              "foreground":  "#8EC5FF"
                                          },
                                "parameter":  {
                                                  "foreground":  "#FFD700"
                                              },
                                "enum":  {
                                             "foreground":  "#8EC5FF"
                                         },
                                "property":  {
                                                 "foreground":  "#A8C0DC"
                                             },
                                "keyword.control":  {
                                                        "foreground":  "#FF7A90",
                                                        "fontStyle":  "bold"
                                                    },
                                "method":  {
                                               "foreground":  "#6EC1FF"
                                           },
                                "variable":  {
                                                 "foreground":  "#D6E2F2"
                                             },
                                "type":  {
                                             "foreground":  "#8EC5FF"
                                         },
                                "keyword":  {
                                                "foreground":  "#FF7A90",
                                                "fontStyle":  "bold"
                                            },
                                "interface":  {
                                                  "foreground":  "#8EC5FF"
                                              },
                                "variable.readonly":  {
                                                          "foreground":  "#F2A7B8"
                                                      },
                                "number":  {
                                               "foreground":  "#FFD700"
                                           },
                                "function":  {
                                                 "foreground":  "#79B8FF"
                                             },
                                "string":  {
                                               "foreground":  "#8ED89A"
                                           },
                                "comment":  {
                                                "foreground":  "#8FA1B5",
                                                "fontStyle":  "italic"
                                            },
                                "namespace":  {
                                                  "foreground":  "#8EC5FF"
                                              },
                                "label":  {
                                              "foreground":  "#FFD700",
                                              "fontStyle":  "bold"
                                          },
                                "macro":  {
                                              "foreground":  "#FFA94D"
                                          }
                            }
}
