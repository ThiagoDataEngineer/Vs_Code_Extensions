<idea-plugin>
  <id>com.thiag.idea.theme.f1rst</id>
  <name>IDEA Theme F1rst</name>
  <vendor email="thiag@example.com">Thiag</vendor>
  <description><![CDATA[
    Tema customizado para IntelliJ IDEA.
  ]]></description>
  <version>0.2.0</version>
  <depends>com.intellij.modules.platform</depends>

  <extensions defaultExtensionNs="com.intellij">
    <themeProvider id="idea-theme-f1rst"
                   path="/theme/idea_theme_f1rst.theme.json" />
    <themeProvider id="vaporwave-red-neon"
                   path="/theme/vaporwave_red.theme.json" />
    <themeProvider id="ghibli-sky-garden"
                   path="/theme/ghibli_sky_garden.theme.json" />
    <themeProvider id="cowboy-terminal-black"
                   path="/theme/cowboy_terminal.theme.json" />
  </extensions>
</idea-plugin>
